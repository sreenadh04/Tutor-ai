# ═══════════════════════════════════════════════════════════════
#  MediTutor AI — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env file to git!
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED: At least ONE of these API keys ─────────────────────────────────

# Groq API Key (PRIMARY — fastest free tier)
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace API Key (FALLBACK — always free)
# Get free key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_token_here

# ── OPTIONAL: Frontend config ─────────────────────────────────────────────────

# URL of the FastAPI backend (used by Streamlit)
# Local dev:  http://localhost:8000/api/v1
# Production: https://your-render-app.onrender.com/api/v1
MEDITUTOR_API_URL=http://localhost:8000/api/v1

# ── OPTIONAL: CORS config (comma-separated list) ─────────────────────────────
# Add your Streamlit Cloud or Vercel URL here in production
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ── OPTIONAL: Debug mode (true/false) ────────────────────────────────────────
DEBUG=false
